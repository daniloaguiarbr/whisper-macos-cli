{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/daniloaguiarbr/whisper-macos-cli/schemas/transcribe-input/v0.1.0.json",
  "title": "TranscribeInput",
  "type": "object",
  "description": "CLI flags accepted by the transcribe subcommand. The CLI itself uses clap derive; this schema is the machine-readable mirror for agent integrators.",
  "properties": {
    "files": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Audio file paths. If empty, stdin is read."
    },
    "language": {
      "type": "string",
      "description": "Language code (pt, en, es, auto). Defaults to OS locale."
    },
    "model": {
      "type": "string",
      "enum": ["tiny", "base", "small", "medium", "large-v3"],
      "default": "large-v3"
    },
    "beam_size": {
      "type": "integer",
      "minimum": 1,
      "maximum": 16,
      "default": 8
    },
    "timestamps": {
      "type": "boolean",
      "default": false,
      "description": "Include timestamped segments in output"
    },
    "ndjson": {
      "type": "boolean",
      "default": false
    },
    "output_format": {
      "type": "string",
      "enum": ["json", "ndjson"]
    },
    "vad_threshold": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "default": 0.5
    },
    "concurrency": {
      "type": "integer",
      "minimum": 1,
      "maximum": 32,
      "default": 2
    },
    "input_format": {
      "type": "string",
      "enum": ["ogg", "mp3", "wav", "flac", "aac", "opus"]
    },
    "dry_run": {
      "type": "boolean",
      "default": false
    },
    "timeout": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3600
    },
    "retry_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10
    },
    "retry_max_elapsed": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3600
    },
    "offline": {
      "type": "boolean",
      "default": false
    },
    "resume": {
      "type": "string"
    }
  }
}
